{
  "name": "scaffold-cache",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --host 0.0.0.0 --port 5174",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx}\"",
    "typecheck": "tsc --noEmit",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "preflight": "node scripts/preflight.mjs",
    "prebuild": "node scripts/preflight.mjs",
    "dev:start": "pnpm run dev:stop >/dev/null 2>&1 || true; caddy start --config ./Caddyfile.agent --adapter caddyfile >/tmp/caddy.log 2>&1; nohup pnpm exec vite dev --host 0.0.0.0 --port 5174 --strictPort >/tmp/vite.log 2>&1 & echo $! > /tmp/vite.pid",
    "dev:stop": "(kill $(cat /tmp/vite.pid 2>/dev/null) 2>/dev/null; pkill -f 'vite dev --host 0.0.0.0 --port 5174' 2>/dev/null; caddy stop 2>/dev/null; rm -f /tmp/vite.pid) || true",
    "dev:restart": "pnpm dev:stop && sleep 1 && pnpm dev:start",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@durable-streams/y-durable-streams": "https://pkg.pr.new/@durable-streams/y-durable-streams@326",
    "@electric-sql/client": "^1.5.14",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/db": "^0.6.4",
    "@tanstack/electric-db-collection": "^0.3.2",
    "@tanstack/offline-transactions": "^1.0.29",
    "@tanstack/react-db": "^0.1.82",
    "@tanstack/react-devtools": "^0.10.0",
    "@tanstack/react-router": "^1.167.4",
    "@tanstack/react-router-devtools": "^1.166.9",
    "@tanstack/react-router-ssr-query": "^1.166.9",
    "@tanstack/react-start": "^1.166.15",
    "@tanstack/router-plugin": "^1.166.13",
    "@tanstack/start-client-core": "*",
    "@tiptap/extension-collaboration": "^3.22.3",
    "@tiptap/extension-collaboration-caret": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "lucide-react": "^1.8.0",
    "next-themes": "^0.4.6",
    "nitro": "latest",
    "postgres": "^3.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "vite-tsconfig-paths": "^5.1.4",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^3.25"
  },
  "devDependencies": {
    "@electric-sql/cli": "https://pkg.pr.new/electric-sql/stratovolt/@electric-sql/cli@1434",
    "@tanstack/devtools-vite": "^0.6.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@tanstack/intent": "^0.0.29",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^27.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "shadcn": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.0.0",
    "web-vitals": "^5.1.0"
  }
}
